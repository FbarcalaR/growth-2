# Postgres connection string (Epic A). Use the value Vercel injects from
# the Neon integration in production / preview; supply a local Docker / Neon
# branch for development. Required when `GROWTH_REPO=prisma`; ignored when
# the in-memory repos are selected.
DATABASE_URL=""

# Repository implementation. `memory` (default) uses the in-memory store
# from Story 0.6 — no external services. `prisma` switches every repo to the
# Postgres-backed impls under `src/server/repositories/prisma/`.
GROWTH_REPO=memory

# Auth.js (Epic B). All three required when `GROWTH_REPO=prisma`; in dev /
# test the dev-stub cookie path bypasses Auth.js entirely.
#
# `AUTH_SECRET` signs the JWT session cookie. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth client. Create at https://console.cloud.google.com →
# APIs & Services → Credentials → Create OAuth client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
